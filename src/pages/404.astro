---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout
  title="Page introuvable – Psycho Santé 74"
  description="Cette page n'existe pas."
>
  <div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center px-6">
      <p class="text-6xl font-bold text-primary mb-4">404</p>
      <h1 class="text-2xl font-bold mb-4">Page introuvable</h1>
      <p class="text-gray-500 mb-8">
        La page que vous cherchez n'existe pas ou a été déplacée.
      </p>
      <a
        href="/"
        class="inline-block bg-primary text-white px-6 py-3 rounded font-semibold hover:bg-primary-dark transition-colors"
      >
        Retour à l'accueil
      </a>
    </div>
  </div>
</MainLayout>
