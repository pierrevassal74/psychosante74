            <p class="text-sm">Tél. : <a href="tel:+33766662054" class="hover:text-primary">07 66 66 20 54</a></p>
            <p class="text-sm">E-mail : <a href="mailto:contact@mariediet.com" class="hover:text-primary">contact@mariediet.com</a></p>
            <p class="text-sm">Site web : <a href="https://www.mariediet.com/" target="_blank" rel="noopener noreferrer" class="hover:text-primary">www.mariediet.com</a></p>
          </div>

          <div>
            <h3 class="font-bold uppercase tracking-wide text-sm text-primary mb-2">SOPHIE DURAND</h3>
            <p class="text-sm">Tél. : <a href="tel:+33670619603" class="hover:text-primary">06 70 61 96 03</a></p>
            <p class="text-sm">E-mail : <a href="mailto:sdurand.ccf@gmail.com" class="hover:text-primary">sdurand.ccf@gmail.com</a></p>
          </div>

          <div>
            <h3 class="font-bold uppercase tracking-wide text-sm text-primary mb-2">ANNE BERTHION</h3>
            <p class="text-sm">Tél. : <a href="tel:+33667893238" class="hover:text-primary">06 67 89 32 38</a></p>
            <p class="text-sm">E-mail : <a href="mailto:aberthion.instantmediation@gmail.com" class="hover:text-primary">aberthion.instantmediation@gmail.com</a></p>
            <p class="text-sm">Site web : <a href="https://mediation74.fr/" target="_blank" rel="noopener noreferrer" class="hover:text-primary">mediation74.fr</a></p>
          </div>

          <div>
            <h3 class="font-bold uppercase tracking-wide text-sm text-primary mb-2">NAOMI ANDRIASON</h3>
            <p class="text-sm">Tél. : <a href="tel:+33659197446" class="hover:text-primary">06 59 19 74 46</a></p>
            <p class="text-sm">E-mail : <a href="mailto:lovecare.naomi@gmail.com" class="hover:text-primary">lovecare.naomi@gmail.com</a></p>
            <p class="text-sm">Site web : <a href="https://lovecare-conseil-thérapie.com/" target="_blank" rel="noopener noreferrer" class="hover:text-primary">lovecare-conseil-thérapie.com</a></p>
          </div>

        </div>

        <!-- Adresse + carte -->
        <div>
          <div class="mb-6">
            <h3 class="font-bold uppercase tracking-wide text-sm text-primary mb-3">CABINET PSYCHO SANTÉ 74</h3>
            <address class="not-italic text-gray-700 leading-relaxed text-sm">
              89 Avenue de Genève<br />
              Montée N° 4 – 1er étage<br />
              74000 Annecy
            </address>
          </div>
          <div class="rounded overflow-hidden shadow-md h-64">
            <iframe
              title="Localisation du cabinet Psycho Santé 74"
              width="100%"
